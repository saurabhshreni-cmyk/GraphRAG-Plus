# Copy to .env and override as needed. All env vars are prefixed with GRAPHRAG_.

# Feature flags
GRAPHRAG_ENABLE_CALIBRATION=true
GRAPHRAG_ENABLE_CONTRADICTION=true
GRAPHRAG_ENABLE_ACTIVE_LEARNING=true
GRAPHRAG_ANALYST_MODE_DEFAULT=false

# Backends / ablation flags
GRAPHRAG_USE_GNN=true
GRAPHRAG_USE_CALIBRATION=true
GRAPHRAG_USE_GRAPH=true
GRAPHRAG_USE_VECTOR=true
GRAPHRAG_USE_TRUST=true

# Thresholds
GRAPHRAG_EXTRACTION_THRESHOLD=0.6
GRAPHRAG_ANSWER_THRESHOLD=0.7
GRAPHRAG_HIGH_UNCERTAINTY_THRESHOLD=0.55

# Reproducibility
GRAPHRAG_RANDOM_SEED=42

# Paths
GRAPHRAG_CACHE_DIR=graphrag_plus/.cache
GRAPHRAG_TEMP_DIR=graphrag_plus/.cache/tmp
GRAPHRAG_OUTPUTS_DIR=graphrag_plus/data/outputs
GRAPHRAG_RUN_LOGS_PATH=graphrag_plus/data/run_logs.jsonl

# Scoring weights
GRAPHRAG_SCORING_W1_SEMANTIC=0.22
GRAPHRAG_SCORING_W2_GRAPH=0.20
GRAPHRAG_SCORING_W3_CONFIDENCE=0.20
GRAPHRAG_SCORING_W4_TRUST=0.20
GRAPHRAG_SCORING_W5_UNCERTAINTY_PENALTY=0.18
